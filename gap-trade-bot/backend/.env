# Google AI API Configuration
# Copy this file to .env and add your actual API key

# Google AI API Key (Required)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_AI_API_KEY="xxx-xxx"

# Optional: Model Configuration
# Available models: gemini-1.5-flash, gemini-1.5-pro, gemini-pro
GOOGLE_AI_MODEL=gemini-1.5-flash

# Optional: Safety Settings (BLOCK_NONE, BLOCK_LOW_AND_ABOVE, BLOCK_MEDIUM_AND_ABOVE, BLOCK_HIGH_AND_ABOVE)
GOOGLE_AI_SAFETY_LEVEL=BLOCK_MEDIUM_AND_ABOVE

# Optional: Maximum response tokens
GOOGLE_AI_MAX_TOKENS=2048

# Optional: Temperature (0.0 to 1.0, higher = more creative)
GOOGLE_AI_TEMPERATURE=0.7

# Optional: Search Configuration
# Number of search results to fetch
SEARCH_MAX_RESULTS=10

# Optional: News Configuration
# Number of days to look back for news
NEWS_DAYS_BACK=7

# Optional: Rate Limiting
# Maximum requests per minute
MAX_REQUESTS_PER_MINUTE=60

# Optional: Cache Configuration
# Enable caching for search results (true/false)
ENABLE_CACHE=true
# Cache duration in seconds
CACHE_DURATION=3600

POLYGON_API_KEY="4CylhlrrwfJpekCA76ni_E9g1jibSTIw"
ALPACA_API_KEY="xx"
ALPACA_API_SECRET="xx"
ANTHROPIC_API_KEY="xxx"
STRIPE_SECRET_KEY="xxx"
STRIPE_WEBHOOK_SECRET="rrrr"
STRIPE_PRICE_BEGINNER="rrt"
STRIPE_PRICE_ADVANCED="rrr"
STRIPE_PRICE_YOGI="fgfg"

# Contact Form Email (Gmail SMTP)
# Use a Gmail App Password (NOT your regular password)
# Generate one at: https://myaccount.google.com/apppasswords
CONTACT_EMAIL_TO="wewm"
CONTACT_EMAIL_FROM="sdf"
GMAIL_APP_PASSWORD="mtff wmtt gcfr qfyz"
SENTRY_DSN="https://dsfs4@sf.ingest.us.sentry.io/sdf"

# Set to true when running local mock testing (enables bot/entry-bot endpoints)
# Set to false (or remove) for production deployment
DAS_ENABLED=true
