meta {
  name: Reset User Password
  type: http
  seq: 13
}

put {
  url: {{baseUrl}}/api/admin/users/{{debug_user_id}}/password
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{session_token}}
  Content-Type: application/json
}

body:json {
  {
    "new_password": "TempPass123!"
  }
}
