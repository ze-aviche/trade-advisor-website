meta {
  name: Add Trade
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/trades
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{session_token}}
  Content-Type: application/json
}

body:json {
  {
    "symbol": "AAPL",
    "side": "B",
    "quantity": 100,
    "price": 150.00,
    "trade_time": "2026-05-23T10:30:00",
    "source": "manual"
  }
}
