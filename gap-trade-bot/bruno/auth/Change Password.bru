meta {
  name: Change Password
  type: http
  seq: 6
}

put {
  url: {{baseUrl}}/api/auth/change-password
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{session_token}}
  Content-Type: application/json
}

body:json {
  {
    "current_password": "OldPassword123!",
    "new_password": "NewPassword123!"
  }
}
